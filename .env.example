# Ollama URL for the backend to connect
# The path '/ollama' will be redirected to the specified backend URL
OLLAMA_BASE_URL='http://localhost:11434'

OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# soev.ai Branding
WEBUI_NAME=soev.ai

# ============================================
# FEATURE FLAGS (SaaS Tier Control)
# These flags apply globally to ALL users including admins.
# Cannot be overridden via admin panel.
# All flags default to True when not set.
# ============================================

# --- Chat Controls ---
# Master toggle for chat controls panel
# FEATURE_CHAT_CONTROLS=True

# Whitelist of chat control sections to show (empty = all sections)
# Valid sections: files, valves, system_prompt, params
# FEATURE_CHAT_CONTROLS_SECTIONS=

# System prompt in chat controls and user settings
# FEATURE_SYSTEM_PROMPT=True

# --- Chat Features ---
# FEATURE_CAPTURE=True                 # Screen capture in chat input
# FEATURE_ARTIFACTS=True               # Artifacts panel
# FEATURE_CHAT_OVERVIEW=True           # Chat overview panel
# FEATURE_NOTES_AI_CONTROLS=True       # AI controls in notes editor
# FEATURE_VOICE=True                   # Voice input/output/call features
# FEATURE_CHANGELOG=True               # Changelog display

# --- Workspace Sections ---
# FEATURE_MODELS=True                  # Custom models workspace
# FEATURE_KNOWLEDGE=True               # Knowledge base workspace
# FEATURE_PROMPTS=True                 # Prompts workspace
# FEATURE_TOOLS=True                   # Tools workspace

# --- Admin Features ---
# FEATURE_PLAYGROUND=True              # Admin playground
# FEATURE_ADMIN_EVALUATIONS=True       # Admin evaluations section
# FEATURE_ADMIN_FUNCTIONS=True         # Admin functions section
# FEATURE_ADMIN_SETTINGS=True          # Admin settings section

# Whitelist of admin settings tabs to show (empty = all tabs)
# Valid tabs: general, connections, models, evaluations, tools, documents, web, code-execution, interface, audio, images, pipelines, db, external-agents
# FEATURE_ADMIN_SETTINGS_TABS=

# ============================================
# EXTERNAL AGENTS API
# ============================================

# When enabled, OpenWebUI routes chat completions through an external agent service
# instead of the built-in LLM/RAG/web search orchestration.
# AGENT_API_ENABLED=false
# AGENT_API_BASE_URL=http://localhost:8200
# AGENT_API_KEY=sk-...   # sent as X-API-Key on every outbound request

# Optional comma-separated list of agent identifiers the admin can select from in
# Admin Settings > External Agents. When empty, the agents service uses its own
# default_agent. When set, the admin's selection is forwarded as an override hint
# in the request payload.
# AGENT_API_AGENTS=agent-one,agent-two,agent-three

# When true, the chat UI fetches the default agent's metadata (e.g.
# welcome_message) from the agent service via GET
# /api/v1/agent/gradient_agent_meta and renders the welcome message above the
# chat in the empty state. Default false — leaves stock behavior untouched.
# PersistentConfig: env seeds the initial value; admins can toggle it in
# Admin Settings > Acceptance and the DB value wins thereafter.
# ENABLE_WELCOME_MESSAGE=false

# ============================================
# OAUTH / SSO (Microsoft EntraID)
# ============================================

# Enable OAuth signup (auto-create users on first SSO login).
# ENABLE_OAUTH_SIGNUP=false

# Restrict OAuth signup to invited emails only.
# When true, only emails with a valid pending invite can sign up via OAuth.
# When false (default), domain-allowlist + invite both grant access (hybrid).
# OAUTH_INVITE_REQUIRED=false

# Comma-separated allowed domains (e.g. soev.ai,example.org). '*' means any.
# OAUTH_ALLOWED_DOMAINS=*

# OIDC backchannel logout — Gradient default differs from upstream (upstream: False).
# Enabled by default so Entra-driven signouts invalidate sessions. Requires Redis
# for JWT revocation. Set to False to fall back to upstream behavior.
# ENABLE_OAUTH_BACKCHANNEL_LOGOUT=True

# ============================================
# CALENDAR + AUTOMATIONS (upstream v0.9.0 features)
# Gradient default differs from upstream — these workspaces are OFF by default
# so tenants must opt in via Helm. Upstream defaults both to True.
# ============================================

# ENABLE_CALENDAR=False
# ENABLE_AUTOMATIONS=False
# AUTOMATION_MAX_COUNT=          # empty = no per-user cap
# AUTOMATION_MIN_INTERVAL=       # empty = no minimum interval; set to 300 (s) at Helm for tenants opting in

# ============================================
# EMAIL INVITES (Microsoft Graph API)
# ============================================

# ENABLE_EMAIL_INVITES=false
# EMAIL_GRAPH_TENANT_ID=
# EMAIL_GRAPH_CLIENT_ID=
# EMAIL_GRAPH_CLIENT_SECRET=
# EMAIL_FROM_ADDRESS=no-reply@soev.ai
# EMAIL_FROM_NAME=Soev
# INVITE_EXPIRY_HOURS=168